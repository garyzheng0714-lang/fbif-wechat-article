WECHAT_APPID=your_appid_here
WECHAT_SECRET=your_secret_here
SERVER_PORT=3002
API_KEY=replace_with_random_token

# Feishu / Lark credentials
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token_here

# Runtime limits
# GO_MEMORY_LIMIT_MB=512

# WeChat API quota
# WECHAT_DAILY_QUOTA_LIMIT=1500
# WECHAT_DAILY_QUOTA_RESERVE=100

# Published article sync
# WECHAT_PUBLISHED_PAGE_SIZE=20
# WECHAT_PUBLISHED_RECENT_PAGES=3
# WECHAT_PUBLISHED_BACKFILL_GROW_PAGES=5

# Optional: enable inline cover/image enrichment in the same sync pass.
# Keep disabled by default for maximum stability.
# WECHAT_SYNC_COVER_INLINE=0
# WECHAT_SYNC_BODY_IMAGES_INLINE=0

# Optional: Aliyun OSS for public media URLs
# OSS_ACCESS_KEY_ID=your_access_key_id
# OSS_ACCESS_KEY_SECRET=your_access_key_secret
# OSS_BUCKET=your_bucket_name
# OSS_REGION=cn-shanghai
# OSS_BUCKET_DOMAIN=your_bucket.oss-cn-shanghai.aliyuncs.com
