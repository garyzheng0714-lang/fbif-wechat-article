WECHAT_APPID=your_appid_here
WECHAT_SECRET=your_secret_here
SERVER_PORT=3002

# Feishu / Lark credentials
FEISHU_APP_ID=your_feishu_app_id_here
FEISHU_APP_SECRET=your_feishu_app_secret_here
FEISHU_BITABLE_APP_TOKEN=your_bitable_app_token_here
FEISHU_BITABLE_TABLE_ID=your_bitable_table_id_here

# WeChat API quota & backfill tuning
# Max WeChat API calls allowed per day (default: 1500). Calls stop when limit is reached.
# WECHAT_DAILY_QUOTA_LIMIT=1500
# Max 7-day chunks processed per backfill run (default: 20 = 140 days of history per day).
# BACKFILL_CHUNKS_PER_RUN=20
